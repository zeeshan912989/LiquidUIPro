{% comment %}
  LiquidUI Pro - Luxury Hero Banner
{% endcomment %}

<section class="luxury-hero-banner" id="Hero-{{ section.id }}">
  <div class="hero-bg">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 3000 | image_tag: class: 'hero-img', loading: 'eager' }}
    {% else %}
      <img src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?auto=format&fit=crop&w=2000&q=80" class="hero-img" alt="Luxury Fashion">
    {% endif %}
    <div class="hero-overlay" style="background: linear-gradient(to bottom, rgba(0,0,0,0.2), rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}));"></div>
  </div>

  <div class="hero-content-wrapper">
    <div class="container">
      <div class="hero-text-box text-{{ section.settings.alignment }}">
        <div class="reveal-anim">
          <span class="hero-badge">{{ section.settings.badge }}</span>
        </div>
        <div class="reveal-anim">
          <h1 class="hero-title">{{ section.settings.title }}</h1>
        </div>
        <div class="reveal-anim">
          <p class="hero-desc">{{ section.settings.desc }}</p>
        </div>
        <div class="hero-actions">
          <a href="{{ section.settings.btn_link }}" class="luxury-btn btn-gold">{{ section.settings.btn_text }}</a>
          {% if section.settings.btn_2_text != blank %}
            <a href="{{ section.settings.btn_2_link }}" class="luxury-btn btn-outline">{{ section.settings.btn_2_text }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Luxury Hero Banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero Image" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 90, "step": 10, "label": "Bottom Overlay Opacity", "default": 40 },
    { "type": "text", "id": "badge", "label": "Badge", "default": "ESTABLISHED 2026" },
    { "type": "text", "id": "title", "label": "Title", "default": "Elegance in Every Detail" },
    { "type": "textarea", "id": "desc", "label": "Description", "default": "Discover a curated selection of timeless fashion pieces designed for the modern individual." },
    { "type": "select", "id": "alignment", "label": "Alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" }
    ], "default": "center" },
    { "type": "text", "id": "btn_text", "label": "Primary Button", "default": "Explore Collection" },
    { "type": "url", "id": "btn_link", "label": "Primary Link" },
    { "type": "text", "id": "btn_2_text", "label": "Secondary Button", "default": "View Lookbook" },
    { "type": "url", "id": "btn_2_link", "label": "Secondary Link" }
  ],
  "presets": [{ "name": "Luxury Hero Banner" }]
}
{% endschema %}

<style>
.luxury-hero-banner {
  position: relative;
  height: 95vh;
  min-height: 700px;
  background: #111;
  overflow: hidden;
  font-family: 'Outfit', sans-serif;
  color: white;
}
.hero-bg { position: absolute; inset: 0; }
.hero-img { width: 100%; height: 100%; object-fit: cover; }
.hero-overlay { position: absolute; inset: 0; }

.hero-content-wrapper { position: relative; z-index: 10; height: 100%; display: flex; align-items: center; padding: 0 40px; }
.container { max-width: 1400px; margin: 0 auto; width: 100%; }

.hero-badge {
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.4em;
  color: #C9A96E;
  margin-bottom: 25px;
  display: inline-block;
  text-transform: uppercase;
}
.hero-title {
  font-size: clamp(50px, 9vw, 110px);
  font-weight: 800;
  line-height: 0.85;
  letter-spacing: -0.05em;
  text-transform: uppercase;
  margin-bottom: 35px;
}
.hero-desc {
  font-size: 18px;
  max-width: 600px;
  line-height: 1.6;
  opacity: 0.7;
  margin-bottom: 50px;
}
.text-center .hero-desc { margin-left: auto; margin-right: auto; }

.hero-actions { display: flex; gap: 20px; }
.text-center .hero-actions { justify-content: center; }

.luxury-btn {
  display: inline-block;
  padding: 22px 50px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.25em;
  text-decoration: none;
  transition: all 0.5s cubic-bezier(0.19, 1, 0.22, 1);
}
.btn-gold { background: #C9A96E; color: white; }
.btn-gold:hover { background: white; color: black; transform: translateY(-5px); }
.btn-outline { border: 1px solid rgba(255,255,255,0.2); color: white; backdrop-filter: blur(10px); }
.btn-outline:hover { background: white; color: black; border-color: white; transform: translateY(-5px); }

@media (max-width: 768px) {
  .hero-content-wrapper { padding: 0 20px; }
  .hero-title { font-size: 50px; }
  .hero-actions { flex-direction: column; width: 100%; }
  .luxury-btn { width: 100%; text-align: center; }
}
</style>
